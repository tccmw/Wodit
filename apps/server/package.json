{
  "name": "@wodit/server",
  "private": true,
  "scripts": {
    "dev": "nest build && start /b \"wodit-server-build\" .\\node_modules\\.bin\\nest.cmd build --watch && node --watch dist\\apps\\server\\src\\main.js",
    "dev:build": "nest build --watch",
    "dev:start": "node --watch dist\\apps\\server\\src\\main.js",
    "build": "nest build",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.10",
    "@nestjs/core": "^11.0.10",
    "@nestjs/platform-express": "^11.0.10",
    "@prisma/client": "^6.16.0",
    "@wodit/types": "workspace:*",
    "@wodit/utils": "workspace:*",
    "prisma": "^6.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.3",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
