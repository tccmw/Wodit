generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  profile   Profile?
  feedbacks Feedback[]
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  nickname            String
  sensitivity         Int      @default(0)
  tempOffset          Float    @default(0)
  homeLat             Float    @default(37.5665)
  homeLng             Float    @default(126.978)
  homeRegion          String   @default("서울특별시 강남구")
  onboardingCompleted Boolean  @default(false)
  spotifyConnected    Boolean  @default(false)
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  spotifyTokenExpires DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id             String         @id @default(cuid())
  userId         String
  status         FeedbackStatus
  weatherJson    String
  recommendation String?
  locationLat    Float
  locationLng    Float
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OutfitItem {
  id          String         @id @default(cuid())
  name        String
  category    OutfitCategory
  thermalBand ThermalBand
  weight      Int            @default(1)
  rainOnly    Boolean        @default(false)
  uvOnly      Boolean        @default(false)
  styleTag    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum FeedbackStatus {
  TOO_COLD
  GOOD
  TOO_HOT
}

enum OutfitCategory {
  TOP
  BOTTOM
  EXTRA
}

enum ThermalBand {
  FREEZING
  COLD
  COOL
  MILD
  WARM
}
